# Credenciais do seu projeto Supabase (painel: Settings -> API).
# Copie este arquivo para .env.local e preencha os valores.
# .env.local NAO e versionado (fica fora do git).

# URL do projeto e chave publica (anon). As duas podem ir para o navegador.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# NUNCA coloque a chave service_role aqui, nem em qualquer variavel VITE_*:
# tudo com prefixo VITE_ e embarcado no navegador e fica visivel ao usuario.
# A service_role e de servidor (Edge Functions), jamais do frontend.
